---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} — Paolo Cetti`} description={post.data.description}>
  <article class="container-content py-24 max-w-3xl">
    <p class="font-mono text-xs text-text-tertiary">
      {post.data.publishedAt.toISOString().slice(0, 10)}
    </p>
    <h1 class="mt-2 text-3xl md:text-4xl font-semibold">{post.data.title}</h1>
    <p class="mt-3 text-text-secondary">{post.data.description}</p>

    <div class="prose prose-invert mt-10">
      <Content />
    </div>
  </article>
</BaseLayout>
