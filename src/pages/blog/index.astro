---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { useTranslations } from "@/i18n/ui";

const locale = "en" as const;
const t = useTranslations(locale);

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime(),
);
---

<BaseLayout locale={locale} title="Blog — Paolo Cetti">
  <section class="container-content py-24">
    <h1 class="text-3xl md:text-4xl font-semibold">{t("sections.blog")}</h1>

    {
      posts.length === 0 ? (
        <p class="mt-6 text-text-secondary">{t("blog.placeholder")}</p>
      ) : (
        <ul class="mt-10 space-y-6">
          {posts.map((post) => (
            <li class="border-b border-border pb-6">
              <a
                href={`/blog/${post.id}`}
                class="block group"
              >
                <p class="font-mono text-xs text-text-tertiary">
                  {post.data.publishedAt.toISOString().slice(0, 10)}
                </p>
                <h2 class="mt-1 text-xl font-medium group-hover:text-accent transition-colors">
                  {post.data.title}
                </h2>
                <p class="mt-2 text-text-secondary">{post.data.description}</p>
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </section>
</BaseLayout>
