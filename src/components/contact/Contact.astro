---
import SectionHeading from "@/components/ui/SectionHeading.astro";
import RevealOnScroll from "@/components/ui/RevealOnScroll.tsx";
import EmailCopyButton from "@/components/contact/EmailCopyButton.tsx";
import { Download, Calendar } from "lucide-react";
import { GithubIcon, LinkedinIcon } from "@/components/ui/BrandIcons.tsx";
import { SOCIAL } from "@/lib/utils";
import { useTranslations, type Locale } from "@/i18n/ui";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const calendlyUrl = import.meta.env.PUBLIC_CALENDLY_URL ?? SOCIAL.calendly;
---

<section
  id="contact"
  class="relative py-24 md:py-32 border-t border-border overflow-hidden scroll-mt-24"
>
  <!-- Animated grid backdrop -->
  <div
    aria-hidden="true"
    class="absolute inset-0 -z-10 opacity-[0.18]"
    style="background-image: linear-gradient(var(--color-border) 1px, transparent 1px), linear-gradient(90deg, var(--color-border) 1px, transparent 1px); background-size: 48px 48px; mask-image: radial-gradient(ellipse at center, black 30%, transparent 75%); -webkit-mask-image: radial-gradient(ellipse at center, black 30%, transparent 75%);"
  >
  </div>

  <div class="container-content text-center max-w-3xl">
    <SectionHeading
      kicker={t("contact.kicker")}
      title={t("sections.contact")}
      align="center"
    />

    <RevealOnScroll client:visible>
      <p class="text-text-secondary text-lg leading-relaxed text-balance">
        {t("contact.leadIn")}
      </p>
    </RevealOnScroll>

    <RevealOnScroll client:visible delay={0.05} className="mt-10">
      <div class="flex flex-col items-center gap-8">
        <EmailCopyButton
          client:load
          email={SOCIAL.email}
          copyLabel={t("common.copyEmail")}
          copiedLabel={t("common.emailCopied")}
        />

        <ul class="flex flex-wrap items-center justify-center gap-3">
          <li>
            <a
              href={SOCIAL.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-full border border-border px-4 py-2 text-sm text-text-secondary hover:border-accent hover:text-accent transition-colors"
            >
              <LinkedinIcon size={14} />
              {t("contact.linkedinLabel")}
            </a>
          </li>
          <li>
            <a
              href={SOCIAL.github}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-full border border-border px-4 py-2 text-sm text-text-secondary hover:border-accent hover:text-accent transition-colors"
            >
              <GithubIcon size={14} />
              {t("contact.githubLabel")}
            </a>
          </li>
          {
            calendlyUrl && (
              <li>
                <a
                  href={calendlyUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 rounded-full border border-border px-4 py-2 text-sm text-text-secondary hover:border-accent hover:text-accent transition-colors"
                >
                  <Calendar size={14} aria-hidden="true" />
                  {t("contact.calendlyLabel")}
                </a>
              </li>
            )
          }
          <li>
            <a
              href="/cv-paolo-cetti.pdf"
              download
              class="inline-flex items-center gap-2 rounded-full bg-accent px-4 py-2 text-sm text-bg-primary hover:bg-accent-hover transition-colors"
            >
              <Download size={14} aria-hidden="true" />
              {t("contact.cvLabel")}
            </a>
          </li>
        </ul>
      </div>
    </RevealOnScroll>
  </div>
</section>
