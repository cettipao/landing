---
import SectionHeading from "@/components/ui/SectionHeading.astro";
import RevealOnScroll from "@/components/ui/RevealOnScroll.tsx";
import { about } from "@/data/portfolio";
import { useTranslations, type Locale } from "@/i18n/ui";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section
  id="about"
  class="container-content py-24 md:py-32 border-t border-border scroll-mt-24"
>
  <SectionHeading kicker={t("about.kicker")} title={t("sections.about")} />

  <div class="grid gap-12 md:grid-cols-[280px_1fr] md:gap-16 items-start">
    <RevealOnScroll client:visible className="relative">
      <div
        class="relative aspect-[4/5] w-full max-w-[300px] rounded-lg overflow-hidden border border-border bg-bg-tertiary group"
      >
        <img
          src="/images/profile.png"
          alt={t("about.photoAlt")}
          loading="lazy"
          decoding="async"
          class="w-full h-full object-cover object-center transition-[filter,transform] duration-500 [filter:saturate(0.55)_contrast(1.05)_brightness(0.92)] group-hover:[filter:none] group-hover:scale-[1.02]"
        />
        {/* Subtle blue tint that fades away on hover — completes the duotone */}
        <div
          aria-hidden="true"
          class="pointer-events-none absolute inset-0 mix-blend-color opacity-60 transition-opacity duration-500 group-hover:opacity-0"
          style="background: linear-gradient(135deg, rgba(59,130,246,0.55), rgba(96,165,250,0.25));"
        >
        </div>
        {/* Bottom-edge gradient + corner kicker for the "designed" feel */}
        <div
          aria-hidden="true"
          class="pointer-events-none absolute inset-x-0 bottom-0 h-1/3"
          style="background: linear-gradient(0deg, rgba(10,10,10,0.55), transparent);"
        >
        </div>
        <p
          class="pointer-events-none absolute bottom-3 left-3 font-mono text-[10px] uppercase tracking-[0.2em] text-text-tertiary"
        >
          // córdoba, ar
        </p>
      </div>
    </RevealOnScroll>

    <div class="flex flex-col gap-5 max-w-2xl">
      {
        about.paragraphs[locale].map((p, i) => (
          <RevealOnScroll client:visible delay={0.05 * i}>
            <p class="text-text-secondary leading-relaxed text-base md:text-lg">
              {p}
            </p>
          </RevealOnScroll>
        ))
      }
    </div>
  </div>

  <RevealOnScroll client:visible className="mt-16">
    <ul
      class="grid grid-cols-2 md:grid-cols-4 gap-4"
      role="list"
      aria-label="Quick stats"
    >
      {
        about.stats.map((stat) => (
          <li class="rounded-lg border border-border bg-bg-tertiary/40 p-5 hover:border-accent/40 transition-colors">
            <p class="text-2xl md:text-3xl font-semibold tracking-tight text-text-primary">
              {stat.value}
            </p>
            <p class="mt-1 font-mono text-xs text-text-tertiary uppercase tracking-wider">
              {stat.label[locale]}
            </p>
          </li>
        ))
      }
    </ul>
  </RevealOnScroll>
</section>
